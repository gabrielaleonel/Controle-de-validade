      "android": {
        "buildType": "apk"
      },
      "env": {
        "NPM_FLAGS": "--legacy-peer-deps"
      }
    },
    "preview-aab": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "NPM_FLAGS": "--legacy-peer-deps"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
