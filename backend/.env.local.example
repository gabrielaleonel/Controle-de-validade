# Turso (banco de dados)
TURSO_DB_URL=libsql://itens-gabrielaleonel.aws-ap-northeast-1.turso.io
TURSO_DB_AUTH_TOKEN=cole_aqui_seu_token

# Resend (envio de e-mail)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="Validade <noreply@seudominio.com>"

# Segredo para proteger rota de cron
CRON_SECRET=cole_um_segredo_forte_aqui

# Segredo para proteger rota de sync (compartilhado com o app mobile)
SYNC_API_KEY=cole_outro_segredo_aqui

# URL do app (usada nos templates de e-mail)
APP_URL=https://validade-email-api.vercel.app

# Fuso horário do usuário
APP_TIMEZONE=America/Sao_Paulo

# Nome do app (usado nos templates)
APP_NAME=Validade

# Slots de envio (formato: morning:HH:MM,afternoon:HH:MM,evening:HH:MM)
# Opcional — fallback para 08:00,14:00,20:00
EXPIRATION_EMAIL_SLOTS=morning:08:00,afternoon:14:00,evening:20:00
